# AgriLabour Point SMS Configuration

# Choice of SMS Provider: 'console' (for local logging), 'twilio', or 'fast2sms'
SMS_PROVIDER=console

# ==========================================
# 1. Twilio Configuration (If using twilio)
# ==========================================
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# 2. Fast2SMS Configuration (If using fast2sms)
# ==========================================
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ==========================================
# 3. MongoDB Configuration
# ==========================================
MONGODB_URI=mongodb://localhost:27017/agrilabour
